<Window x:Class="OrbitalTracker.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helix="http://helix-toolkit.org/wpf"
        xmlns:views="clr-namespace:OrbitalTracker.Views"
        Title="Orbital Tracker v1.0" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetName="DetailPanelTransform"
                         Storyboard.TargetProperty="X"
                         To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="SlideOutAnimation">
            <DoubleAnimation Storyboard.TargetName="DetailPanelTransform"
                         Storyboard.TargetProperty="X"
                         To="-320" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid Background="#111116">
        <helix:HelixViewport3D x:Name="MainViewport" 
                               ZoomExtentsWhenLoaded="True" 
                               ShowCoordinateSystem="False"
                               Background="Black"
                               MouseDown="MainViewport_MouseDown">
            <helix:SunLight />
            <helix:SphereVisual3D Radius="6371" PhiDiv="32" ThetaDiv="32">
                <helix:SphereVisual3D.Material>
                    <DiffuseMaterial>
                        <DiffuseMaterial.Brush>
                            <ImageBrush ImageSource="/Resources/earth_texture.jpg" />
                        </DiffuseMaterial.Brush>
                    </DiffuseMaterial>
                </helix:SphereVisual3D.Material>
            </helix:SphereVisual3D>
        </helix:HelixViewport3D>

        <DockPanel LastChildFill="False" Margin="20">

            <Grid DockPanel.Dock="Left" VerticalAlignment="Top">
                <Grid.RenderTransform>
                    <TranslateTransform x:Name="DetailPanelTransform" X="-320"/>
                </Grid.RenderTransform>
                <views:SatelliteDetailView x:Name="SatelliteDetailPanel" />
            </Grid>
            <views:FilterPanelView x:Name="FilterPanel" DockPanel.Dock="Right" VerticalAlignment="Top"/>

            <Border DockPanel.Dock="Bottom" Background="#CC1E1E24" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8" Padding="20,10" HorizontalAlignment="Center" Margin="0,0,0,25">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Button x:Name="BtnPause" Content="⏸ Durdur" Click="BtnPause_Click" Width="80" Padding="5" Background="#22FFFFFF" Foreground="White" BorderBrush="#44FFFFFF" Margin="0,0,15,0"/>
                        <Button x:Name="BtnPlay" Content="▶ Başlat" Click="BtnPlay_Click" Width="80" Padding="5" Background="#FF10B981" Foreground="White" BorderThickness="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0,0,0">
                        <TextBlock Text="Hız: " Foreground="#A0A0A0" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <RadioButton x:Name="RbSpeed1" Content="1x" Tag="1" IsChecked="True" Checked="SpeedRadioButton_Checked" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <RadioButton x:Name="RbSpeed10" Content="10x" Tag="10" Checked="SpeedRadioButton_Checked" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <RadioButton x:Name="RbSpeed100" Content="100x" Tag="100" Checked="SpeedRadioButton_Checked" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DockPanel>
        <Grid x:Name="LoadingOverlay" Background="#E605050A" Visibility="Visible">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🛰" FontSize="60" HorizontalAlignment="Center" Margin="0,0,0,15">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="SpinnerTransform" CenterX="30" CenterY="30"/>
                    </TextBlock.RenderTransform>
                    <TextBlock.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SpinnerTransform" 
                                             Storyboard.TargetProperty="Angle" 
                                             From="0" To="360" Duration="0:0:2" RepeatBehavior="Forever"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </TextBlock.Triggers>
                </TextBlock>

                <TextBlock Text="UZAY AĞINA BAĞLANILIYOR..." Foreground="#FF3B82F6" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Gerçek zamanlı TLE yörünge verileri indiriliyor" Foreground="#A0A0A0" FontSize="13" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
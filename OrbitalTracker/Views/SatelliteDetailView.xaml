<UserControl x:Class="OrbitalTracker.Views.SatelliteDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="280" Background="#CC1E1E24">

    <Border BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8" Padding="15">
        <StackPanel>
            <TextBlock Text="UYDU DETAYLARI" Foreground="#FF3B82F6" FontSize="12" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBlock Text="ISS (ZARYA)" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

            <Separator Background="#22FFFFFF" Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,10">
                <TextBlock Text="NORAD ID:" Foreground="#A0A0A0"/>
                <TextBlock Text="25544" Foreground="White" HorizontalAlignment="Right" FontWeight="SemiBold"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <TextBlock Text="Yörünge Türü:" Foreground="#A0A0A0"/>
                <TextBlock Text="LEO (Alçak İrtifa)" Foreground="White" HorizontalAlignment="Right" FontWeight="SemiBold"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <TextBlock Text="Yükseklik:" Foreground="#A0A0A0"/>
                <TextBlock Text="421.5 km" Foreground="#FF10B981" HorizontalAlignment="Right" FontWeight="SemiBold"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <TextBlock Text="Anlık Hız:" Foreground="#A0A0A0"/>
                <TextBlock Text="27,560 km/s" Foreground="#FF10B981" HorizontalAlignment="Right" FontWeight="SemiBold"/>
            </Grid>

            <Separator Background="#22FFFFFF" Margin="0,0,0,15"/>

            <TextBlock Text="Anlık Koordinatlar" Foreground="#A0A0A0" FontSize="11" Margin="0,0,0,8"/>
            <UniformGrid Columns="2" Margin="0,0,0,5">
                <StackPanel>
                    <TextBlock Text="Enlem" Foreground="#707070" FontSize="10"/>
                    <TextBlock Text="40.15° N" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Boylam" Foreground="#707070" FontSize="10"/>
                    <TextBlock Text="26.40° E" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </UniformGrid>
        </StackPanel>
    </Border>
</UserControl>